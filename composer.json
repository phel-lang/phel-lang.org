{
    "name": "phel-lang/phel-website",
    "keywords": [
        "phel",
        "lisp",
        "functional",
        "language"
    ],
    "homepage": "https://phel-lang.org/",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "phel-lang/phel-lang": "^0.45",
        "gacela-project/gacela": "^1.15"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^10.5",
        "symfony/var-dumper": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "PhelWeb\\": "build/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhelWebTests\\": "build/tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.4"
        }
    },
    "scripts": {
        "build": [
            "php build/api-page.php",
            "php build/api-search.php",
            "php build/api-json.php",
            "php build/generate-releases.php",
            "php build/generate-repl-showcase.php",
            "php build/generate-error-reference.php"
        ],
        "test": "./vendor/bin/phpunit",
        "test:snippets": "php build/run-doc-snippets.php",
        "post-update-cmd": [
            "php build/update-phel-version.php"
        ]
    }
}
